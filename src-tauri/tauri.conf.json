{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aras Antivirus",
  "version": "1.6.0",
  "identifier": "com.umutins62.aras-antivirus",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Aras Antivirus",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "tooltip": "Aras Antivirus"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "umutins62",
    "category": "Utility",
    "shortDescription": "Aras Antivirus",
    "longDescription": "Modern security and system optimization for Windows"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/palamut62/aras_antivirus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMjlCNTNEODk4QzVDMzMKUldRelhJeUpQYlVwY1VwV201TDRQMGM2OTFiMGZ1QnNJSEVscmtuVjJWbTdiZEVTdFJSUmhvcGkK"
    }
  }
}
